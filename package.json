{
  "name": "automation-trigger",
  "version": "1.3.0",
  "description": "",
  "license": "MIT",
  "author": {
    "name": "Riley MacDonald"
  },
  "keywords": [
    "qlik",
    "automation"
  ],
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=8"
  },
  "main": "dist/automation-trigger.js",
  "module": "dist/automation-trigger.esm.js",
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "build:watch": "rollup -c rollup.config.js -w",
    "lint": "eslint src",
    "start": "nebula serve --no-build",
    "sense": "npm run build && nebula sense --ext src/extDefinition.js --meta ./meta.json --sourcemap true && python3 ../extension_build/build.py --type extension --extension-path . --tenant coe-emea.eu.qlikcloud.com"
  },
  "devDependencies": {
    "@babel/core": "7.4.5",
    "@babel/cli": "7.4.4",
    "@babel/plugin-transform-react-jsx": "7.3.0",
    "@babel/preset-env": "7.4.5",
    "@babel/preset-react": "7.0.0",
    "@babel/preset-typescript": "^7.28.5",
    "@nebula.js/cli": "1.0.2-alpha.1",
    "@nebula.js/cli-build": "1.0.2-alpha.1",
    "@nebula.js/cli-sense": "1.0.2-alpha.1",
    "@nebula.js/cli-serve": "1.0.2-alpha.1",
    "@rollup/plugin-commonjs": "^17.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "eslint": "5.12.1",
    "eslint-config-airbnb": "17.1.0",
    "eslint-plugin-import": "2.15.0",
    "eslint-plugin-jsx-a11y": "6.2.1",
    "eslint-plugin-mocha": "5.2.1",
    "eslint-plugin-react": "7.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rollup": "^2.30.0",
    "rollup-plugin-babel": "4.3.2",
    "rollup-plugin-node-resolve": "5.0.0",
    "rollup-plugin-postcss": "2.0.3",
    "rollup-plugin-replace": "2.2.0"
  },
  "peerDependencies": {
    "@nebula.js/stardust": "^1.x"
  },
  "dependencies": {
    "@qlik/sprout-icons": "^0.3.0",
    "@qlik/sprout-react": "^6.45.2",
    "@reduxjs/toolkit": "^1.5.0",
    "clipboard-copy": "^4.0.1",
    "date-fns": "^2.25.0",
    "react-redux": "^7.2.2"
  }
}
